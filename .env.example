# Bumblebot environment configuration
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# No ANTHROPIC_API_KEY needed — Bumblebot shells out to the `claude` CLI and
# is billed through your existing Claude Code subscription. Make sure `claude`
# is on PATH before running ./install (see https://claude.com/product/claude-code).

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Comma-separated Telegram user IDs allowed to talk to the bot
# REQUIRED — bot refuses to start if empty
# Find your user ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWLIST=

# Postgres connection URL (pgvector + BM25 extensions required)
# Recommended: free Supabase project (https://supabase.com)
DATABASE_URL=postgres://user:password@host:5432/bumblebot

# Display name for your bot — used in greetings and logs
BOT_NAME=Bumblebot

# Google Gemini API key for embedding generation
GEMINI_API_KEY=your-gemini-key-here

# Runtime environment: development | production
NODE_ENV=development
